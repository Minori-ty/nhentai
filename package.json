{
    "name": "@nhentai/monorepo",
    "version": "1.0.0",
    "description": "",
    "keywords": [],
    "license": "ISC",
    "author": "",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "dev:extension": "pnpm --filter nhentai-extension dev",
        "dev:tampermonkey": "pnpm --filter nhentai-tampermonkey dev",
        "build:extension": "pnpm --filter nhentai-extension build",
        "build:tampermonkey": "pnpm --filter nhentai-tampermonkey build",
        "build": "pnpm run build:extension & pnpm run build:tampermonkey",
        "compile:extension": "pnpm --filter nhentai-extension compile",
        "compile:tampermonkey": "pnpm --filter nhentai-tampermonkey exec vue-tsc -b",
        "compile": "pnpm run compile:extension && pnpm run compile:tampermonkey",
        "check": "pnpm run compile && pnpm run build",
        "lint": "oxlint",
        "format": "oxfmt",
        "prepare": "husky"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "oxfmt": "^0.55.0",
        "oxlint": "^1.70.0",
        "oxlint-tailwindcss": "^1.3.3"
    },
    "lint-staged": {
        "*.{ts,vue,md,json}": [
            "oxfmt",
            "oxlint --fix"
        ]
    }
}
