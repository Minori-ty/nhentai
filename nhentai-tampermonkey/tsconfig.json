{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "jsx": "preserve",
        "noEmit": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@nhentai/shared/*": ["../packages/shared/src/*"],
            "@/*": ["../packages/shared/src/*"]
        }
    },
    "include": ["src/**/*", "../packages/shared/src/**/*"]
}
